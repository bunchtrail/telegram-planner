# Telegram Planner — пример переменных окружения
# Скопируйте в `.env.local` и заполните реальными значениями.
# `.env.local` уже игнорируется git (.gitignore: `.env*`).

# ── Публичные (видны в браузере) ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...

# (опционально) метаданные приложения
NEXT_PUBLIC_APP_NAME=Planner App
NEXT_PUBLIC_APP_DESCRIPTION=Telegram Mini App Planner
NEXT_PUBLIC_APP_LANG=ru
# NEXT_PUBLIC_TELEGRAM_SCRIPT_URL=https://telegram.org/js/telegram-web-app.js

# Только для локальной разработки: эмуляция Telegram initData.
# В продакшене НЕ задавайте.
# NEXT_PUBLIC_TELEGRAM_INIT_DATA=

# ── Серверные секреты (никогда не префиксуйте NEXT_PUBLIC_) ─────────────────
TELEGRAM_BOT_TOKEN=123456:ABCDEF...your-bot-token...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-project-settings
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key...

# Секрет для cron-эндпоинта /api/reminders/run (отправляется в заголовке
# `x-reminders-secret`). Сгенерируйте длинную случайную строку:
#   openssl rand -hex 32
REMINDERS_RUN_SECRET=replace-with-long-random-string

# ── Node runtime ────────────────────────────────────────────────────────────
NODE_ENV=production
# Адрес и порт, на которых слушает Next.js standalone server.
# Для деплоя за reverse-proxy (cloudflared / nginx / caddy) держите 127.0.0.1.
HOSTNAME=127.0.0.1
PORT=3000
